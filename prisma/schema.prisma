generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Advertisement {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  redirectUrl String
  placement   String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}